# Скопировать в .env. Все переменные опциональны — дефолты берутся из config.yaml.

# Путь к конфигу (по умолчанию ./config.yaml)
# CONFIG_PATH=config.yaml

# Переопределения config.yaml (двойное подчёркивание = вложенность):
# SERVER__PORT=8000
# WORKER__REFRESH_INTERVAL_MINUTES=360
# SCORING__DEFAULT_PRESET=balanced

# Токен HuggingFace — нужен только если датасет потребует авторизации.
# HF_TOKEN=

# OpenRouter — публичный list моделей ключа не требует. Указать, если упрётесь в лимиты.
# OPENROUTER_API_KEY=
